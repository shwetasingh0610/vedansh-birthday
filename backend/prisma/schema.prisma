// Prisma schema — https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Wish {
  id        String   @id @default(uuid())
  name      String?
  message   String
  createdAt DateTime @default(now())

  @@map("wishes")
}

model Rsvp {
  id        String   @id @default(uuid())
  name      String
  attending Boolean
  guests    Int      @default(0)
  message   String?
  createdAt DateTime @default(now())

  @@map("rsvps")
}
